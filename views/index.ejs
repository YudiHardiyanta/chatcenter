<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <title><%= title %></title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/particles.js"></script>

    <style>
        body {
            background-size: cover;
            background-position: center;
        }
    </style>

</head>

<body class="min-h-screen flex flex-col relative">

    <!-- overlay -->
    <div class="absolute inset-0 bg-orange-600/80"></div>

    <!-- particle -->

    <!-- content wrapper -->
    <div class="relative flex flex-col min-h-screen">

        <!-- NAVBAR -->
        <nav class="bg-white/90 backdrop-blur-md shadow-md">

            <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">

                <div class="text-xl font-bold text-orange-500">
                    🔥 Chat Center BPS Provinsi Bali
                </div>

                <ul class="flex space-x-6 text-gray-700 font-medium">
                    <li><a href="/logout" class="hover:text-orange-500">Logout</a></li>
                </ul>

            </div>

        </nav>

        <!-- MAIN CONTENT -->
        

            <section>
                <iframe src="<%= iframeUrl %>" frameborder="0" width="100%" height="780vh"
                    allowtransparency></iframe>
            </section>

        

        <!-- FOOTER -->
        <footer class="bg-white/90 backdrop-blur-md text-center py-4 text-gray-600">

            © <%= year %> Chat Center BPS Provinsi Bali

        </footer>

    </div>

    

</body>

</html>